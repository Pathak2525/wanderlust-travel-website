
<% layout("/layouts/boilerplate") %>
</h1>
<div class="row mt-3">
    <h1 class="col-6 offset-3">SignUP on Wanderlust</h1>
    <div class="col-6 offset-3">
        <form action="/signup" method="POST" novalidate class="needs-validation" novlidate>

            <div class="md-3">
               <lable for="username" class="form-label">Username</lable>

               <input name="username" id="username" type="text" class="form-control" required />

               <div class="vaild-feedback">Looks good!</div>
            </div>

             <br/>

            <div class="md-3">
               <lable for="email" class="form-label">Email</lable>

               <input name="email" id="email" type="email" class="form-control" required />
            </div>


            <br/>


            <div class="md-3">
               <lable for="password" class="form-label">Password</lable>

               <input name="password" id="password" type="password" class="form-control" required />
            </div>

             <br/>

            <button class="btn btn-success">SignUP</button>
        </form>
    </div>
</div>