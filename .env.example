# Cloudinary Credentials for Image Uploads
CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUD_API_KEY=your_cloudinary_api_key_here
CLOUD_API_SECRET=your_cloudinary_api_secret_here

# Mapbox Token for Maps & Geocoding
MAPBOX_TOKEN=your_mapbox_access_token_here

# MongoDB Database Connection String
ATLASDB_URL=mongodb+srv://<username>:<password>@cluster0.mongodb.net/wanderlust?retryWrites=true&w=majority

# Express Session Secret
SECRET=your_super_secret_session_string_here